# =============================================================================
# Agent Data Fabric — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# LLM — Azure OpenAI (primary)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_DEPLOYMENT=gpt-4o
API_VERSION=2024-05-01-preview

# LLM — Ollama (fallback when Azure OpenAI is not configured)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_DB=agent_data_fabric
POSTGRES_USER=adf_user
POSTGRES_PASSWORD=adf_secret_password_change_me

# Encryption — Fernet key for credential encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT Authentication
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Service ports
BACKEND_PORT=7790
FRONTEND_PORT=7791
MCP_SERVER_PORT=7792
MCP_INSPECTOR_PORT=6274

# Internal URLs (used for inter-service communication)
MCP_SERVER_URL=http://localhost:7792/sse
BACKEND_URL=http://localhost:7790

# Application
APP_NAME=Agentic Data Fabric
DEBUG=false
LOG_LEVEL=INFO

# Docker MCP Hub
DOCKER_HOST=unix:///var/run/docker.sock
MCP_FILESYSTEM_PATH=/tmp/adf-files
